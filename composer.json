{
    "name": "amazon/laravel-boost-amazon-q",
    "description": "Laravel Boost extension package that provides Amazon Q Developer integration.",
    "keywords": [
        "laravel",
        "boost",
        "ai",
        "amazon",
        "aws",
        "amazon-q",
        "amazon-q-developer"
    ],
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Amazon Web Services",
            "homepage": "https://aws.amazon.com"
        }
    ],
    "support": {
        "issues": "https://github.com/aws/laravel-boost-amazon-q/issues",
        "source": "https://github.com/aws/laravel-boost-amazon-q"
    },
    "require": {
        "php": "^8.2",
        "illuminate/support": "^11.0|^12.0|^13.0",
        "laravel/boost": "^2.0"
    },
    "require-dev": {
        "laravel/pint": "^1.0"
    },
    "autoload": {
        "psr-4": {
            "Amazon\\LaravelBoostAmazonQ\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Amazon\\LaravelBoostAmazonQ\\AmazonQServiceProvider"
            ]
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
